rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(ownerUid) {
      return isAuth() && request.auth.uid == ownerUid;
    }
    function notDeleted() {
      return resource.data.isDeleted != true;
    }
    // True if the authenticated user owns the Vehicles/{vehicleId} document.
    // Used as a legacy fallback for child docs that may not yet carry ownerUid.
    function ownsVehicleId(vehicleId) {
      return isAuth()
        && vehicleId is string
        && exists(/databases/$(database)/documents/Vehicles/$(vehicleId))
        && get(/databases/$(database)/documents/Vehicles/$(vehicleId)).data.ownerUid == request.auth.uid;
    }
    // Read access if the doc has ownerUid matching the user, OR (legacy)
    // ownerUid is missing but vehicleId resolves to a Vehicle the user owns.
    function canReadOwned() {
      return isAuth() && (
        (resource.data.ownerUid == request.auth.uid) ||
        (!('ownerUid' in resource.data) && ownsVehicleId(resource.data.vehicleId))
      );
    }
    function canCreateOwned() {
      return isAuth() && request.resource.data.ownerUid == request.auth.uid;
    }

    // ── Users (profile sync từ app) ──
    match /users/{uid} {
      allow read, update: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ── Vehicles ──
    match /Vehicles/{vehicleId} {
      allow read: if isAuth() && isOwner(resource.data.ownerUid);
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if isAuth() && isOwner(resource.data.ownerUid);
    }

    // ── ChargeLogs ──
    match /ChargeLogs/{logId} {
      allow read: if canReadOwned() && notDeleted();
      allow create: if canCreateOwned();
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if false;
    }

    // ── ChargeSamples (AI training data - implicit collection) ──
    // App writes training samples; backend aggregates for fine-tuning
    match /ChargeSamples/{sampleId} {
      allow read: if canReadOwned() && notDeleted();
      allow create: if canCreateOwned();
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if false;
    }

    // ── TripLogs ──
    match /TripLogs/{tripId} {
      allow read: if canReadOwned() && notDeleted();
      allow create: if canCreateOwned();
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if false;
    }

    // ── MaintenanceTasks ──
    match /MaintenanceTasks/{taskId} {
      allow read: if canReadOwned() && notDeleted();
      allow create: if canCreateOwned();
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if false;
    }

    // ── TelemetryPoints ──
    match /TelemetryPoints/{pointId} {
      allow read: if canReadOwned() && notDeleted();
      allow create: if canCreateOwned();
      allow update: if false;
      allow delete: if false;
    }

    // ── battery_states (real-time SOC snapshots written by app) ──
    match /battery_states/{stateId} {
      allow read: if canReadOwned();
      allow create: if canCreateOwned();
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if false;
    }

    // ── trip_predictions (AI prediction history) ──
    match /trip_predictions/{predictionId} {
      allow read: if canReadOwned();
      allow create: if canCreateOwned();
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if isAuth() && isOwner(resource.data.ownerUid);
    }

    // ── soc_predictions (AI SOC prediction history) ──
    match /soc_predictions/{predictionId} {
      allow read: if canReadOwned();
      allow create: if canCreateOwned();
      allow update: if isAuth() && isOwner(resource.data.ownerUid);
      allow delete: if false;
    }

    // ── VinFastModelSpecs (public read, no client write) ──
    match /VinFastModelSpecs/{modelId} {
      allow read: if true;
      allow write: if false; // Managed via backend/admin
    }

    // ── AiVehicleInsights (app reads own data, backend writes via Admin SDK) ──
    match /AiVehicleInsights/{vehicleId} {
      allow read: if isAuth() && isOwner(resource.data.ownerUid);
      allow write: if false; // Managed via backend Admin SDK only
    }

    // ── AiVehicleProfiles (backend only via Admin SDK) ──
    match /AiVehicleProfiles/{vehicleId} {
      allow read, write: if false;
    }

    // ── AuditLogs (backend only) ──
    match /AuditLogs/{logId} {
      allow read, write: if false;
    }

    // ── AiModelDeployments (PLAN1: AI deployment lifecycle) ──
    // Backend/admin only write; authenticated users can read
    match /AiModelDeployments/{typeKey} {
      allow read: if isAuth();
      allow write: if false; // Managed via backend Admin SDK only
    }

    // ── UserNotifications ──
    match /UserNotifications/{notificationId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
