# ══════════════════════════════════════════════════════════════
# VinFast Battery — Docker Environment Variables
# Copy file này thành .env rồi điền giá trị thật
# ══════════════════════════════════════════════════════════════

# ── Bảo mật nội bộ ────────────────────────────────────────────
# Token xác thực giữa Flask API ↔ AI Server
AI_SERVER_INTERNAL_TOKEN=change-me-secret-token-32chars

# Key bypass admin cho dev/internal tool (X-Admin-Key header)
DEV_ADMIN_KEY=change-me-admin-key

# ── Quyền Admin ───────────────────────────────────────────────
# Danh sách email admin, phân cách bằng dấu phẩy
# Dùng * để tất cả tài khoản đều là admin (chỉ cho dev)
ADMIN_EMAILS=admin@yourdomain.com

# ── Firebase Admin SDK (backend) ──────────────────────────────
# Cách tạo: base64 -w 0 vinfast-...-firebase-adminsdk.json
# Trên Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))
FIREBASE_CREDENTIALS_JSON=

# ── Firebase Web Config (React dashboard) ─────────────────────
# Lấy từ Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
